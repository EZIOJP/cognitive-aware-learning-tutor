# Copy to .env and adjust

JWT_SECRET=change-this-in-production
DEV_MODE=true
APP_ENV=development
CORS_ORIGINS=*

# EEG: UDP on 5005 + WebSocket /ws/eeg (0 = use frontend simulation only)
EEG_ENABLED=0

# Local AI (optional — needs working laptop + Ollama; off by default, no GPU required)
OLLAMA_ENABLED=0
# OLLAMA_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2
# OLLAMA_VISION_MODEL=llava

# Python focus mirror → hub (paste JWT after login)
FACE_TRACKER_TOKEN=
