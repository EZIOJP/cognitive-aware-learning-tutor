# Copy to .env and adjust (see docs/DEPENDENCIES.md)

# --- LAN / WiFi (optional — frontend auto-detects when opened via http://YOUR_IP:5173) ---
# Backend already binds 0.0.0.0:8000 via run scripts. Allow ports 5173 + 8000 in firewall.
# VITE_API_URL=http://192.168.1.10:8000
# VITE_VOCAB_API_BASE=http://192.168.1.10:8000/api/vocab
# VITE_WS_URL=ws://192.168.1.10:8000/ws/eeg
# FACE_TRACKER_STATUS_URL=http://localhost:8000/api/vocab/face/status

# --- Auth & app ---
JWT_SECRET=change-this-in-production
DEV_MODE=true
APP_ENV=development
CORS_ORIGINS=*

# --- Database (SQLite default; Postgres later) ---
# DATABASE_URL=sqlite:///./data/vocab_app.db

# --- Vocab seed ---
SEED_WORDS_ON_STARTUP=true
WORDS_SOURCE=auto

# --- EEG: UDP :5005 + WebSocket /ws/eeg (0 = frontend simulation only) ---
EEG_ENABLED=0

# --- Math OCR (TexTeller ONNX, CPU — optional) ---
# TEXTELLER_MODEL_ID=Ji-Ha/TexTeller3-ONNX-dynamic
# TEXTELLER_CACHE_DIR=models/texteller

# --- NVIDIA NIM (Gemma AI Review + vision teacher — optional) ---
# NIM_API_KEY=
# NIM_MODEL=google/gemma-4-31b-it
# NIM_VISION_MODEL=nvidia/nemotron-nano-vl-8b-v1
# NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# --- Local AI (optional — Ollama, LM Studio, or Google Gemini) ---
OLLAMA_ENABLED=1
# lmstudio | ollama | openai | gemini
LLM_PROVIDER=lmstudio
OLLAMA_URL=http://127.0.0.1:1234
# Load this model in LM Studio (Local Server → Start Server)
OLLAMA_MODEL=google/gemma-4-e4b
LLM_API_KEY=lm-studio
# Gemini (cloud — requests go to Google, not LM Studio):
# LLM_PROVIDER=gemini
# OLLAMA_MODEL=gemini-2.0-flash
# LLM_API_KEY=your-key-from-aistudio.google.com
LLM_MAX_TOKENS=8192
# Corpus grounded notes (hybrid RAG writer); 1 = cite textbook + lecture chunks
CORPUS_GROUNDED_NOTES=1
# OpenAI-compatible fallback (vLLM, older LM Studio):
# LLM_PROVIDER=openai
# OLLAMA_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_VISION_MODEL=llava

# --- Python focus mirror → hub (paste JWT after login) ---
FACE_TRACKER_TOKEN=

# --- Frontend (optional .env.local — Vite exposes VITE_* only) ---
# VITE_API_BASE=http://localhost:8000
# VITE_VOCAB_API_BASE=http://localhost:8000/api/vocab
