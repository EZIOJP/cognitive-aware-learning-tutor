# Copy to .env and adjust for local or production.

DATABASE_URL=sqlite:///data/vocab_app.db
JWT_SECRET=generate-a-long-random-secret
JWT_ALGO=HS256
JWT_EXPIRE_MINUTES=10080

# development | production
APP_ENV=development
DEV_MODE=true

# Local admin panel only — never true in production
EXPOSE_PASSWORD_PLAIN=true

# auto = DB when seeded, else JSON; db | json force one source
WORDS_SOURCE=auto

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

GROUP_SIZE=30
MASTERY_MASTERED=6
